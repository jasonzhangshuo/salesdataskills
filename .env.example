# ──────────────────────────────────────────────────────────────────────────────
# salesdataskills 凭据配置模板
# 复制本文件为 .env 并填写真实值：
#   cp .env.example .env
# .env 已加入 .gitignore，不会提交到 git。
# ──────────────────────────────────────────────────────────────────────────────

# ── CRM / 企微接口 ─────────────────────────────────────────────────────────────
# CRM API token（JWT），三选一，优先级：INTERNAL_API_KEY > WORKWX_API_KEY > CRM_TOKEN
INTERNAL_API_KEY=

# CRM 接口 base URL（必填）
# 示例：https://crm.your-company.com/crmapi
CRM_BASE_URL=

# CRM 服务路径前缀（可选，默认 /api/system-bigdata-crm-web）
# CRM_SERVICE_PREFIX=/api/system-bigdata-crm-web

# ── Metabase ───────────────────────────────────────────────────────────────────
# Metabase 实例地址（必填），不含路径，如 https://metabase.your-company.com
METABASE_HOST=

# ── 本地数据库路径（可选，默认 ~/Documents/salesdataskills/local.db）────────────
# DATA_REPO_DB_PATH=~/Documents/salesdataskills/local.db
